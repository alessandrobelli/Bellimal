{{!< default}}

<div class="bml-home">

  {{!-- Band 1 ── Terminal hero. The faux markup renders as-is without JS;
        terminal.js progressively enhances it into an interactive prompt. --}}
  <section class="bml-terminal" data-terminal-root aria-label="Terminal">
    <div class="bml-terminal__chrome">
      <span class="bml-terminal__lights" aria-hidden="true">
        <span class="bml-terminal__dot bml-terminal__dot--red"></span>
        <span class="bml-terminal__dot bml-terminal__dot--yellow"></span>
        <span class="bml-terminal__dot bml-terminal__dot--green"></span>
      </span>
      <span class="bml-terminal__filename">~/{{@site.title}}</span>
      <button class="bml-terminal__hint" data-terminal-hint type="button"
              title="Show help (or type `help`)" aria-label="Show help">?</button>
    </div>
    <div class="bml-terminal__body">
      <div class="bml-terminal__scroll" data-terminal-output aria-live="polite">
        <p class="bml-terminal__prompt">whoami</p>
        <p class="bml-terminal__output bml-terminal__output--title">{{{@custom.hero_title}}}</p>
        <p class="bml-terminal__prompt">cat focus.txt</p>
        <div class="bml-terminal__output">{{{@custom.hero_description}}}</div>
      </div>
      <div class="bml-terminal__input-line" data-terminal-input-line>
        <span class="bml-terminal__prompt-marker" aria-hidden="true">$</span>
        <span class="bml-terminal__cursor-content"
          ><span class="bml-terminal__cursor-text">_</span><span class="bml-terminal__cursor" aria-hidden="true"></span></span>
      </div>
    </div>
  </section>

  {{> "cta-staple"}}

  {{!-- Band 2 ── // FEATURED: one project, hero treatment.
        Prefer a project tagged @custom.projects_tag AND featured:true.
        If none, fall back to the most recent project in the tag.
        If no project exists at all, the section silently skips. --}}
  {{#get "posts" filter="tag:{{@custom.projects_tag}}+featured:true"
                 limit="1" include="tags,authors"}}
    {{#if posts}}
      {{#foreach posts}}{{> "featured-section" label="featured projects"}}{{/foreach}}
    {{else}}
      {{#get "posts" filter="tag:{{@custom.projects_tag}}"
                     limit="1" include="tags,authors"}}
        {{#foreach posts}}{{> "featured-section" label="featured projects"}}{{/foreach}}
      {{/get}}
    {{/if}}
  {{/get}}

  {{!-- Band 3 ── // MORE PROJECTS: 2-/3-column grid of mini cards.
        Renders only when 2+ projects exist (otherwise the only project
        is already in the Featured band above and we'd show it twice). --}}
  {{#get "posts" filter="tag:{{@custom.projects_tag}}"
                 limit="6" include="tags,authors"}}
    {{#if posts.[1]}}
      <section class="bml-listing">
        <header class="bml-listing__head">
          <span class="bml-label-mono">// more projects</span>
          <a href="/tag/{{@custom.projects_tag}}/" class="bml-posts__all">
            all projects ({{pagination.total}}) →
          </a>
        </header>
        <div class="bml-card-grid">
          {{#foreach posts}}{{> "post-card"}}{{/foreach}}
        </div>
      </section>
    {{/if}}
  {{/get}}

  {{!-- Band 4 ── // LATEST WRITING: editorial list of non-project posts.
        tag:-X is NQL's "not tagged X" filter — projects don't appear
        twice on the page. --}}
  {{#get "posts" filter="tag:-{{@custom.projects_tag}}"
                 limit="5" include="tags,authors"}}
    {{#if posts}}
      <section class="bml-posts">
        <header class="bml-posts__head">
          <span class="bml-label-mono">// latest writing</span>
          <a href="/" class="bml-posts__all">
            all posts ({{pagination.total}}) →
          </a>
        </header>
        <ul class="bml-posts__list">
          {{#foreach posts}}
            <li class="bml-post-row">
              <a href="{{url}}" class="bml-post-row__link">
                <div class="bml-post-row__thumb">
                  {{#if feature_image}}
                    {{> "responsive-img"
                        src=feature_image
                        alt=title
                        sizes="120px"}}
                  {{else}}
                    <span class="bml-post-row__placeholder" aria-hidden="true"></span>
                  {{/if}}
                </div>
                <div class="bml-post-row__body">
                  <div class="bml-post-row__meta">
                    <span>{{date format="MMM DD"}}</span>
                    <span aria-hidden="true">·</span>
                    <span>{{reading_time minute="1 MIN" minutes="% MIN"}}</span>
                    {{#primary_tag}}
                      <span aria-hidden="true">·</span>
                      <span class="bml-post-row__tag">{{name}}</span>
                    {{/primary_tag}}
                    <span aria-hidden="true">·</span>
                    <span class="bml-post-row__slug" title="cat {{slug}}">{{slug}}</span>
                  </div>
                  <h3 class="bml-post-row__title">
                    {{#if featured}}<span class="bml-post-row__fire" aria-hidden="true">🔥</span>{{/if}}
                    {{title}}
                  </h3>
                  <p class="bml-post-row__excerpt">{{excerpt words="22"}}</p>
                </div>
              </a>
            </li>
          {{/foreach}}
        </ul>
      </section>
    {{/if}}
  {{/get}}

  {{!-- ─ Server-rendered data for terminal.js ────────────────────────────
       Hidden DOM. JS reads via dataset / textContent — robust against any
       quotes or specials in titles, no JSON-encoding gymnastics required. --}}
  <div hidden data-terminal-data>
    <span data-bml="hero-title">{{{@custom.hero_title}}}</span>
    <span data-bml="hero-description">{{{@custom.hero_description}}}</span>
    <span data-bml="contact">{{#if @custom.contact_email}}{{@custom.contact_email}}{{else}}hello@example.com{{/if}}</span>
    <ul data-bml="nav">
      {{#foreach @site.navigation}}
        <li data-label="{{label}}" data-url="{{url}}"></li>
      {{/foreach}}
    </ul>
    {{#get "tags" limit="10" order="count.posts desc" include="count.posts"}}
      <ul data-bml="tags">
        {{#foreach tags}}
          <li data-name="{{name}}" data-slug="{{slug}}" data-url="{{url}}" data-count="{{count.posts}}"></li>
        {{/foreach}}
      </ul>
    {{/get}}
    {{#get "posts" limit="5"}}
      <ul data-bml="posts">
        {{#foreach posts}}
          <li data-title="{{title}}" data-slug="{{slug}}" data-url="{{url}}" data-date="{{date format='YYYY-MM-DD'}}" data-reading-time="{{reading_time minute='1 min' minutes='% min'}}" data-excerpt="{{excerpt words='20'}}"></li>
        {{/foreach}}
      </ul>
    {{/get}}
    {{!-- All published, fully-public posts/pages (slug + title + url only) —
         feeds tab completion and `cat`/`cd` lookups. {{#get}} from a theme
         can never see drafts; `visibility:public` further excludes member-
         only or paid content from leaking even just their slugs. --}}
    {{#get "posts" limit="100" filter="visibility:public" fields="slug,title,url"}}
      <ul data-bml="all-posts">
        {{#foreach posts}}
          <li data-slug="{{slug}}" data-title="{{title}}" data-url="{{url}}"></li>
        {{/foreach}}
      </ul>
    {{/get}}
    {{#get "pages" limit="50" filter="visibility:public" fields="slug,title,url"}}
      <ul data-bml="all-pages">
        {{#foreach pages}}
          <li data-slug="{{slug}}" data-title="{{title}}" data-url="{{url}}"></li>
        {{/foreach}}
      </ul>
    {{/get}}
  </div>

</div>
