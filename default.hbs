<html lang="en" class="no-transition-on-load">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{meta_title}}</title>

    {{!-- Ghost-injected meta + scripts + cards.min.css. Placing this early
         so its preconnects to Ghost's CDN/comments/portal fire ASAP. As a
         side effect, our main.css below loads after cards.min.css, so
         same-specificity overrides in main.css win without specificity
         hacks (the `.kg-card.kg-X` selectors in bookmarks.css are kept
         defensive and harmless). --}}
    {{ghost_head}}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">

    {{!-- Favicons (theme-bundled, override Ghost's auto-injected one) --}}
    <link rel="icon" type="image/svg+xml" href="{{asset 'favicon.svg'}}" />
    <link rel="apple-touch-icon" href="{{asset 'apple-touch-icon.svg'}}" />

    {{!-- Single compiled stylesheet — input.css @imports prism, bookmarks,
         social-embeds, then Tailwind base/components/utilities. --}}
    <link rel="stylesheet" href="{{asset 'css/main.css'}}" />

    <script>
      if (localStorage.getItem('darkMode') === 'true') {
        document.documentElement.classList.add('dark');
      } else if (localStorage.getItem('darkMode') === null && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  {{!-- Body styles (bg/text/font/transitions) come from `body { @apply ... }`
       in input.css — no inline duplicate needed. --}}
  <body>

    {{!-- Mobile sticky topbar (browser-chrome aesthetic) ────────────────── --}}
    <header class="bml-topbar tab:hidden">
      <div class="bml-topbar__lights" aria-hidden="true">
        <span class="bml-topbar__dot bml-topbar__dot--red"></span>
        <span class="bml-topbar__dot bml-topbar__dot--yellow"></span>
        <span class="bml-topbar__dot bml-topbar__dot--green"></span>
      </div>
      <a href="{{@site.url}}" class="bml-topbar__title">~/{{@site.title}}</a>
      <div class="bml-topbar__actions">
        <button id="darkModeToggleMobile" class="bml-topbar__icon-btn" type="button"
                aria-label="Toggle dark mode">
          {{> "icons/theme-toggle"}}
        </button>
        <button id="hamburgerBtn" class="bml-topbar__icon-btn" type="button"
                aria-label="Open menu">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
               stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </header>

    <div class="flex flex-col min-h-screen tab:flex-row">
      {{!-- Sidebar (drawer on mobile, fixed on desktop) ─────────────────── --}}
      <aside id="sideNav" aria-label="Site sidebar"
             class="bml-sidebar-shell -translate-x-full tab:translate-x-0 transition-transform duration-300">
        <button id="closeNavBtn" class="bml-sidebar-close tab:hidden" type="button"
                aria-label="Close menu">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
               stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
        {{> "sidebar"}}
      </aside>

      <main class="bml-main">
        {{{body}}}
      </main>
    </div>

    {{!-- defer is essentially a no-op when scripts are at end-of-body, but
         declaring intent + harmless when the parser hasn't reached this
         point yet (e.g. server push). --}}
    <script src="{{asset 'js/darkmode.js'}}" defer></script>
    <script src="{{asset 'js/mobile-menu.js'}}" defer></script>
    <script src="{{asset 'js/sidebar.js'}}" defer></script>
    <script src="{{asset 'js/social-embeds.js'}}" defer></script>
    <script src="{{asset 'js/share.js'}}" defer></script>
    {{!-- Prism is ~68KB and only post/page bodies use <pre><code> --}}
    {{#is "post, page"}}
      <script src="{{asset 'js/lib/prism.js'}}" defer></script>
    {{/is}}
    {{#is "home"}}
      <script src="{{asset 'js/terminal.js'}}" defer></script>
    {{/is}}
    {{ghost_foot}}
  </body>
</html>
