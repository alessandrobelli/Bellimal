{{!< default}}

{{#tag}}
<header class="bml-page-hero{{#unless feature_image}} bml-page-hero--no-image{{/unless}}">
  {{#if feature_image}}
    <img class="bml-page-hero__bg" src="{{img_url feature_image size="xl"}}" alt="" aria-hidden="true" />
  {{/if}}
  <div class="bml-page-hero__overlay" aria-hidden="true"></div>
  <div class="bml-page-hero__inner">
    <span class="bml-label-mono">// tag</span>
    <h1 class="bml-page-hero__title">{{name}}</h1>
    <p class="bml-page-hero__subtitle">
      {{#if description}}{{description}}{{else}}Posts tagged {{name}}{{/if}}
    </p>
  </div>
</header>
{{/tag}}

<section class="bml-listing">
  {{#if posts}}
    <div class="bml-card-grid">
      {{#foreach posts}}
        {{> "post-card"}}
      {{/foreach}}
    </div>
    {{pagination}}
  {{else}}
    <p class="bml-listing__empty">No posts in this tag yet.</p>
  {{/if}}
</section>
