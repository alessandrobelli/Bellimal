{{!-- Share row — three circle buttons. Copy-link uses navigator.clipboard
     (handled by assets/js/share.js); Twitter & LinkedIn open share intents. --}}
<section class="bml-share" aria-label="Share">
  <span class="bml-label-mono">// share</span>
  <ul class="bml-share__list">
    <li>
      <a href="https://x.com/intent/tweet?url={{url absolute="true"}}&text={{encode title}}"
         target="_blank" rel="noopener noreferrer"
         class="bml-share__btn" aria-label="Share on X">
        <svg class="bml-share__icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="m 17.7 0 h 4.05 l -7.575 8.625 l 8.85 11.7 h -6.945 l -5.4375 -7.11 l -6.225 7.11 h -3.45 l 8.025 -9.225 l -8.475 -11.1 h 7.1175 l 4.9125 6.495 z m -1.2075 18.3 h 1.9125 l -12.375 -16.35 h -2.055 z"/>
        </svg>
      </a>
    </li>
    <li>
      <a href="https://www.linkedin.com/shareArticle?mini=true&url={{url absolute="true"}}&title={{encode title}}&summary={{encode excerpt}}"
         target="_blank" rel="noopener noreferrer"
         class="bml-share__btn" aria-label="Share on LinkedIn">
        <svg class="bml-share__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    </li>
    <li>
      <button type="button" class="bml-share__btn" data-copy-link="{{url absolute="true"}}"
              aria-label="Copy link to this post">
        <svg class="bml-share__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
        </svg>
        <span class="bml-share__feedback" aria-live="polite"></span>
      </button>
    </li>
  </ul>
</section>
