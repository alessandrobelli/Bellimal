{{!-- "You might like" — 3 latest public posts. Avoid mustache interpolation
     inside the filter (Ghost {{#get}} parses filter strings cautiously and
     {{id}} can blow up on page contexts). --}}
{{#get "posts" limit="3" filter="visibility:public" include="tags,authors" as |related|}}
  {{#if related}}
    <section class="bml-listing bml-listing--related">
      <header class="bml-listing__head">
        <span class="bml-label-mono">// you might like</span>
      </header>
      <div class="bml-card-grid">
        {{#foreach related}}
          {{> "post-card"}}
        {{/foreach}}
      </div>
    </section>
  {{/if}}
{{/get}}
