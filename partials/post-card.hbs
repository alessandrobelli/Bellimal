{{!-- Card used by tag, index, author, error templates and the
     "you might like" partial. Brief-critical CSS:
       box-sizing: border-box; min-width: 0; overflow: hidden;
       image: width 100%; aspect-ratio: 16/9; object-fit: cover;
     so cards never blow out of their grid cell. --}}
<article class="bml-card{{#if featured}} bml-card--featured{{/if}}">
  <a href="{{url}}" class="bml-card__link">
    <div class="bml-card__media">
      {{#if feature_image}}
        {{> "responsive-img"
            src=feature_image
            alt=title
            imgClass="bml-card__img"
            sizes="(min-width: 900px) 280px, 100vw"}}
      {{else}}
        <span class="bml-card__placeholder" aria-hidden="true"></span>
      {{/if}}
      {{#primary_tag}}
        <span class="bml-card__tag">#{{name}}</span>
      {{/primary_tag}}
    </div>
    <div class="bml-card__body">
      <h3 class="bml-card__title">
        {{#if featured}}<span class="bml-card__fire" aria-hidden="true">🔥</span>{{/if}}
        {{title}}
      </h3>
      {{#if excerpt}}
        <p class="bml-card__excerpt">{{excerpt words="22"}}</p>
      {{/if}}
      <div class="bml-card__meta">
        <span>{{date format="MMM DD, YYYY"}}</span>
        <span aria-hidden="true">·</span>
        <span>{{reading_time minute="1 MIN" minutes="% MIN"}}</span>
      </div>
    </div>
  </a>
</article>
