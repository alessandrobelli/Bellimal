{{!< default}}

{{#author}}
<header class="bml-author-hero">
  {{#if profile_image}}
    <img class="bml-author-hero__avatar" src="{{img_url profile_image size="m"}}" alt="" loading="lazy" decoding="async" />
  {{else}}
    <span class="bml-author-hero__avatar bml-author-hero__avatar--fallback" aria-hidden="true">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 4l4 4-4 4"/>
        <path d="M9 12h4"/>
      </svg>
    </span>
  {{/if}}
  <div class="bml-author-hero__body">
    <span class="bml-label-mono">// author</span>
    <h1 class="bml-author-hero__name">{{name}}</h1>
    {{#if bio}}<p class="bml-author-hero__bio">{{bio}}</p>{{/if}}
    <div class="bml-author-hero__meta">
      {{#if location}}<span class="bml-author-hero__location">{{location}}</span>{{/if}}
      {{#if website}}
        <a class="bml-author-hero__link" href="{{website}}" target="_blank" rel="noopener noreferrer">website ↗</a>
      {{/if}}
      {{!-- Manual URL construction — twitter_url/facebook_url helpers are
            deprecated in Ghost 6. {{twitter}} / {{facebook}} return the
            stored handle. --}}
      {{#if twitter}}
        <a class="bml-author-hero__link" href="https://x.com/{{twitter}}" target="_blank" rel="noopener noreferrer">{{twitter}} ↗</a>
      {{/if}}
      {{#if facebook}}
        <a class="bml-author-hero__link" href="https://www.facebook.com/{{facebook}}" target="_blank" rel="noopener noreferrer">facebook ↗</a>
      {{/if}}
    </div>
  </div>
</header>
{{/author}}

<section class="bml-listing">
  {{#if posts}}
    <div class="bml-card-grid">
      {{#foreach posts}}
        {{> "post-card"}}
      {{/foreach}}
    </div>
    {{pagination}}
  {{else}}
    <p class="bml-listing__empty">No posts by this author yet.</p>
  {{/if}}
</section>
