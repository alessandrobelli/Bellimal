{{!< default}}

<div class="flex flex-col items-center py-12">
    {{#if profile_image}}
        <img class="w-28 h-28 rounded-full object-cover border-4 border-gray-200 dark:border-gray-700" src="{{profile_image}}" alt="{{name}}">
    {{/if}}
    <h1 class="mt-4 text-2xl font-heading text-anthracite dark:text-darkText">{{name}}</h1>
</div>

<main class="container mx-auto px-4 pb-8">
    <div class="post-cards grid grid-cols-1 gap-8 max-w-3xl mx-auto">
        {{#foreach posts}}
            {{> "post-card"}}
        {{/foreach}}
    </div>

    {{pagination}}
</main>
