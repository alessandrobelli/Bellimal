{{!< default}}

<header class="bml-page-hero bml-page-hero--no-image">
  <div class="bml-page-hero__overlay" aria-hidden="true"></div>
  <div class="bml-page-hero__inner">
    <span class="bml-label-mono">// index</span>
    <h1 class="bml-page-hero__title">All posts</h1>
    {{#if @site.description}}
      <p class="bml-page-hero__subtitle">{{@site.description}}</p>
    {{/if}}
  </div>
</header>

<section class="bml-listing">
  {{#if posts}}
    <div class="bml-card-grid">
      {{#foreach posts}}
        {{> "post-card"}}
      {{/foreach}}
    </div>
    {{pagination}}
  {{else}}
    <p class="bml-listing__empty">No posts yet.</p>
  {{/if}}
</section>
