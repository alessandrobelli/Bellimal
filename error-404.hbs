{{!< default}}

<section class="bml-error">
  <div class="bml-terminal" aria-label="404">
    <div class="bml-terminal__chrome">
      <span class="bml-terminal__lights" aria-hidden="true">
        <span class="bml-terminal__dot bml-terminal__dot--red"></span>
        <span class="bml-terminal__dot bml-terminal__dot--yellow"></span>
        <span class="bml-terminal__dot bml-terminal__dot--green"></span>
      </span>
      <span class="bml-terminal__filename">~/404</span>
    </div>
    <div class="bml-terminal__body">
      <div class="bml-terminal__scroll">
        <p class="bml-terminal__prompt">cd {{statusCode}}</p>
        <p class="bml-terminal__line bml-terminal__line--error">command not found: {{statusCode}}</p>
        <p class="bml-terminal__prompt">help</p>
        <p class="bml-terminal__line">try one of these instead:</p>
        <p class="bml-terminal__line">
          <a class="bml-terminal__line bml-terminal__line--link" href="{{@site.url}}">→ go home</a>
        </p>
      </div>
    </div>
  </div>

  <p class="bml-error__caption">
    <span class="bml-label-mono">// 404</span> {{statusCode}} · {{message}}
  </p>

  <section class="bml-listing bml-listing--related">
    <header class="bml-listing__head">
      <span class="bml-label-mono">// or read something</span>
    </header>
    <div class="bml-card-grid">
      {{#get "posts" limit="3" filter="visibility:public" include="tags,authors" as |fallback|}}
        {{#if fallback}}
          {{#foreach fallback}}
            {{> "post-card"}}
          {{/foreach}}
        {{/if}}
      {{/get}}
    </div>
  </section>
</section>
