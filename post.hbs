{{!< default}}

{{#post}}
<article class="bml-post {{post_class}}">

  {{!-- Hero band ─ <img> with object-fit: cover (more predictable than
        background-image), overlay fade, then centered title + byline. ─── --}}
  <header class="bml-post-hero{{#unless feature_image}} bml-post-hero--no-image{{/unless}}">
    {{#if feature_image}}
      {{> "responsive-img"
          src=feature_image
          alt=""
          imgClass="bml-post-hero__bg"
          sizes="(min-width: 900px) 920px, 100vw"
          loading="eager"
          fetchpriority="high"
          hidden="true"}}
    {{/if}}
    <div class="bml-post-hero__overlay" aria-hidden="true"></div>
    <div class="bml-post-hero__inner">
      <h1 class="bml-post-hero__title">{{title}}</h1>
      <div class="bml-post-hero__byline">
        <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="D MMM YYYY"}}</time>
        <span aria-hidden="true">·</span>
        <span>{{reading_time minute="1 MIN" minutes="% MIN"}}</span>
        {{#primary_tag}}
          <span aria-hidden="true">·</span>
          <a href="{{url}}" class="bml-post-hero__tag">{{name}}</a>
        {{/primary_tag}}
        {{#if authors}}
          <span aria-hidden="true">·</span>
          <span class="bml-post-hero__author">Written by
            {{#foreach authors}}
              <a href="{{url}}" class="bml-post-hero__author-link">
                {{#if profile_image}}
                  <img src="{{img_url profile_image size="xs"}}" alt="" class="bml-post-hero__avatar" loading="lazy" decoding="async" />
                {{/if}}
                <span>{{name}}</span>
              </a>
            {{/foreach}}
          </span>
        {{/if}}
      </div>
    </div>
  </header>

  {{!-- Body ─ prose-styled content (.bml-prose, redesigned per brief) ── --}}
  <div class="bml-post-body">
    <div class="bml-prose">
      {{content}}
    </div>
  </div>

  {{!-- Footer ─ share row + comments + continue-reading card ──────────── --}}
  <footer class="bml-post-footer">
    {{> "share-block"}}
    {{comments color-scheme="auto"}}

    {{!-- Continue reading: prefer prev_post, fall back to next_post.
          Both render if both exist; CSS hides the second one. --}}
    {{#prev_post}}
      <section class="bml-continue">
        <span class="bml-label-mono">// continue reading</span>
        <a href="{{url}}" class="bml-continue__card">
          <span class="bml-continue__pill">Previous Post</span>
          <h3 class="bml-continue__title">{{title}}</h3>
          {{#if excerpt}}<p class="bml-continue__excerpt">{{excerpt words="22"}}</p>{{/if}}
          <span class="bml-continue__more">Read more →</span>
        </a>
      </section>
    {{/prev_post}}
    {{#next_post}}
      <section class="bml-continue">
        <span class="bml-label-mono">// continue reading</span>
        <a href="{{url}}" class="bml-continue__card">
          <span class="bml-continue__pill">Next Post</span>
          <h3 class="bml-continue__title">{{title}}</h3>
          {{#if excerpt}}<p class="bml-continue__excerpt">{{excerpt words="22"}}</p>{{/if}}
          <span class="bml-continue__more">Read more →</span>
        </a>
      </section>
    {{/next_post}}
  </footer>

</article>
{{/post}}
