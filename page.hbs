{{!< default}}

{{#page}}
<article class="bml-post bml-page {{page_class}}">

  {{!-- Hero band — only renders when the page has the "Show title and
        feature image" toggle enabled in Ghost admin. ──────────────────── --}}
  {{#if @page.show_title_and_feature_image}}
    <header class="bml-post-hero{{#unless feature_image}} bml-post-hero--no-image{{/unless}}">
      {{#if feature_image}}
        {{> "responsive-img"
            src=feature_image
            alt=""
            imgClass="bml-post-hero__bg"
            sizes="(min-width: 900px) 920px, 100vw"
            loading="eager"
            fetchpriority="high"
            hidden="true"}}
      {{/if}}
      <div class="bml-post-hero__overlay" aria-hidden="true"></div>
      <div class="bml-post-hero__inner">
        <h1 class="bml-post-hero__title">{{title}}</h1>
        <div class="bml-post-hero__byline">
          <span>Last updated</span>
          <span aria-hidden="true">·</span>
          <time datetime="{{date updated_at format='YYYY-MM-DD'}}">{{date updated_at format='D MMM YYYY'}}</time>
          {{#if authors}}
            <span aria-hidden="true">·</span>
            <span class="bml-post-hero__author">Written by
              {{#foreach authors}}
                <a href="{{url}}" class="bml-post-hero__author-link">
                  {{#if profile_image}}
                    <img src="{{img_url profile_image size="xs"}}" alt="" class="bml-post-hero__avatar" loading="lazy" decoding="async" />
                  {{/if}}
                  <span>{{name}}</span>
                </a>
              {{/foreach}}
            </span>
          {{/if}}
        </div>
      </div>
    </header>
  {{/if}}

  {{!-- Body — prose-styled content --}}
  <div class="bml-post-body">
    <div class="bml-prose">
      {{content}}
    </div>
  </div>

  {{!-- You might like — 3 latest posts --}}
  {{> "you-might-like"}}
</article>
{{/page}}
